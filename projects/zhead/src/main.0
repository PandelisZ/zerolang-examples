// zhead - print the first N argument-lines.
//
// Modeled on coreutils `head`. Each argument is one line (this backend has
// no stdin/file runtime). Prints the first N lines; default N = 10.
//
//   zhead -n 2 a b c
//   a
//   b
use lib

pub fn main(world: World) -> Void raises {
    let argc: usize = std.args.len()
    if argc < 2 {
        check world.err.write("usage: zhead [-n N] line...\n")
        return
    }
    var data_start: usize = 1
    var limit: u32 = 10_u32
    let fa: Maybe<String> = std.args.get(1)
    if fa.has {
        if std.mem.eql(fa.value, "-n") {
            if argc < 3 {
                check world.err.write("zhead: -n requires a count\n")
                return
            }
            let na: Maybe<String> = std.args.get(2)
            if na.has {
                let ns: Span<u8> = std.mem.span(na.value)
                if is_all_digits(ns) {
                    limit = parse_u32(ns)
                } else {
                    check world.err.write("zhead: invalid count\n")
                    return
                }
            }
            data_start = 3
        }
    }
    // Count data args.
    var ci: usize = data_start
    var total: u32 = 0
    while ci < argc {
        total = total + 1
        ci = ci + 1
    }
    let emit: u32 = clamp_count(limit, total)
    var i: usize = data_start
    var printed: u32 = 0
    while i < argc {
        if printed < emit {
            let av: Maybe<String> = std.args.get(i)
            if av.has {
                check world.out.write(av.value)
                check world.out.write("\n")
                printed = printed + 1
            }
        }
        i = i + 1
    }
}
